# Flask Configuration
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=3000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# LLM Configuration - Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alternative: OpenAI GPT
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4

# Computer Vision Configuration
CV_ENABLE_ADVANCED=true
CV_CONFIDENCE_THRESHOLD=0.75

# AR Configuration
AR_ENABLE=true
AR_FORMAT=gltf

# Database (if using persistent storage)
DATABASE_URL=sqlite:///homedesign.db

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# File Upload Configuration
MAX_UPLOAD_SIZE=50
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Catalog storage (saved designs, screenshots, etc.)
CATALOGS_FOLDER=./catalogs

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Features
ENABLE_AR=true
ENABLE_ANALYTICS=false
ENABLE_USER_AUTH=false

# Agentic Configuration
AGENT_REASONING_DEPTH=3
AGENT_TIMEOUT=300

# Default Values
DEFAULT_ROOM_WIDTH=5.0
DEFAULT_ROOM_HEIGHT=2.8
DEFAULT_ROOM_LENGTH=5.0
